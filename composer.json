{
    "name": "typicms/laravel-translatable-bootforms",
    "description": "Empowers typicms/bootforms with typicms/laravel-translatable.",
    "keywords": [
        "laravel",
        "bootforms",
        "translatable",
        "i18n",
        "form"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Propaganistas",
            "email": "Propaganistas@users.noreply.github.com"
        },
        {
            "name": "Samuel De Backer",
            "email": "sdebacker@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "~10.0|~11.0|~12.0|~13.0",
        "typicms/form": "^4.0.0",
        "typicms/bootforms": "^5.0.0",
        "typicms/translatable": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0",
        "larastan/larastan": "^2.11.2|^3.9",
        "laravel/pint": "^1.20",
        "pestphp/pest": "^1.20|^v2.0|^v3.0|^4.0",
        "driftingly/rector-laravel": "^1.0|^2.1"
    },
    "autoload": {
        "psr-4": {
            "TypiCMS\\LaravelTranslatableBootForms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TypiCMS\\LaravelTranslatableBootForms\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "TypiCMS\\LaravelTranslatableBootForms\\TranslatableBootFormsServiceProvider"
            ],
            "aliases": {
                "TranslatableBootForm": "TypiCMS\\LaravelTranslatableBootForms\\Facades\\TranslatableBootForm"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
